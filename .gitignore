#####################################################################
# WAFFLL SYSTEM / G01DN STANDARD
# File: .gitignore
# Version: v1.2.0
# Purpose: Defines excluded files for WAFFLL main-site repository
# Scope: main-site (Next.js interface layer + WAFFLL system support)
# Last Updated: 2026-06-19
#####################################################################

# =========================
# CORE DEPENDENCIES
# =========================

node_modules/

# =========================
# NEXT.JS OUTPUT
# =========================

.next/
out/
dist/
build/

# =========================
# ENVIRONMENT
# =========================

.env
.env.local
.env.production
.env.* 
!.env.example

# =========================
# LOGS
# =========================

logs/
*.log

# =========================
# SYSTEM / OS FILES
# =========================

.DS_Store

# =========================
# IDE / EDITOR
# =========================

.vscode/
.idea/

# =========================
# TEST / COVERAGE
# =========================

coverage/

# =========================
# GENERATED OUTPUT LAYER
# (safe to ignore - derived artifacts only)
# =========================

output/

# =========================
# LOCAL SNAPSHOTS / EXPERIMENTS
# =========================

system/snapshots/
content/drafts/

# =========================
# OPTIONAL LOCAL CACHE / TEMP BUILD ARTIFACTS
# =========================

.cache/
.tmp/
temp/
